{
  "version": 1,
  "profile": "custom",
  "projectName": "custom-example",
  "deploymentProfile": "docker-local",
  "toolingProfile": "none",
  "runtimeProfile": "stable-chat",
  "queueProfile": "stable-chat",
  "instructionFiles": [
    "README.md",
    ".openclaw/instructions.md"
  ],
  "knowledgeFiles": [
    ".openclaw/knowledge.md"
  ],
  "verificationCommands": [],
  "agent": {
    "id": "workspace",
    "name": "Custom Example Workspace"
  },
  "telegram": {
    "dmPolicy": "pairing",
    "groupPolicy": "disabled",
    "streamMode": "partial",
    "replyToMode": "first"
  },
  "acp": {
    "defaultAgent": "codex"
  },
  "security": {
    "authBootstrapMode": "external"
  }
}
