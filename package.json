{
  "name": "openclaw-repo-agent",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "description": "npm-first packaging for reusable OpenClaw, Telegram, and ACP repo agent flows.",
  "license": "MIT",
  "homepage": "https://github.com/AndriiTeterka/openclaw-repo-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndriiTeterka/openclaw-repo-agent.git"
  },
  "bugs": {
    "url": "https://github.com/AndriiTeterka/openclaw-repo-agent/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "telegram",
    "acp",
    "agent",
    "automation"
  ],
  "bin": {
    "openclaw-repo-agent": "./cli/bin/openclaw-repo-agent.mjs"
  },
  "files": [
    "cli/**/*",
    "runtime/**/*",
    "schemas/**/*",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "figures": "^6.1.0",
    "inquirer": "^13.3.2",
    "log-symbols": "^7.0.1",
    "ora": "^9.3.0",
    "string-width": "^8.2.0"
  },
  "scripts": {
    "check": "node ./cli/bin/openclaw-repo-agent.mjs config validate --repo-root ./examples/custom --product-root . --json",
    "test:unit": "node --test",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run test:unit && npm run check && npm run pack:dry-run",
    "test": "npm run release:check",
    "prepublishOnly": "npm run release:check"
  }
}
